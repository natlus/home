---
import Layout from "../layouts/Layout.astro";

import { Computer } from "@lucide/astro";
import { MapPinHouse } from "@lucide/astro";
---

<Layout>
  <div class="flex flex-col gap-8">
    <div class="gap-05 flex flex-col">
      <h1>about</h1>
      <p class="flex items-center gap-1">
        <Computer size={16} /> software developer @ Sveriges Radio.
      </p>
      <p class="flex items-center gap-1">
        <MapPinHouse size={16} /> Malmö, Sweden.
      </p>
    </div>

    <div class="flex flex-col gap-2">
      <div class="relative">
        <h2>work</h2>
        <div
          class="after:bg-primary/20 after-z-1 grid grid-cols-[auto_auto_1fr_125px] items-center after:absolute after:h-px after:w-full"
        >
          <span class="text-orange bg-background z-2 pr-1">Sveriges Radio</span>
          <span class="text-muted bg-background z-2 px-1">
            fullstack developer
          </span>
          <span></span>
          <span class="bg-background z-2 ml-auto w-full pl-1">2022-</span>
        </div>
      </div>

      <div class="relative">
        <div
          class="after:bg-primary/20 after-z-1 grid grid-cols-[auto_auto_1fr_125px] items-center after:absolute after:h-px after:w-full"
        >
          <span class="text-orange bg-background z-2 pr-1">Prisjakt</span>
          <span class="text-muted bg-background z-2 px-1">web developer</span>
          <span></span>
          <span class="bg-background z-2 ml-auto w-full pl-1">2017-2022</span>
        </div>
      </div>

      <div class="relative">
        <div
          class="after:bg-primary/20 after-z-1 grid grid-cols-[auto_auto_1fr_125px] items-center after:absolute after:h-px after:w-full"
        >
          <span class="text-orange bg-background z-2 pr-1">Nortech</span>
          <span class="text-muted bg-background z-2 px-1">web developer</span>
          <span></span>
          <span class="bg-background z-2 ml-auto w-full pl-1">2015-2017</span>
        </div>
      </div>
    </div>
  </div>
</Layout>
