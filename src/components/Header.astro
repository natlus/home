---
import NavLink from "./nav-link";
import { ArrowUpRight } from "@lucide/astro";
---

<header class="py-3">
  <nav class="flex flex-row gap-3">
    <NavLink client:load href="/" shortcut="h">
      <span>[h]</span><span>home</span>
    </NavLink>
    <NavLink client:load href="/projects" shortcut="p">
      <span>[p]</span><span>projects</span>
    </NavLink>
    <NavLink
      client:load
      href="https://github.com/natlus"
      target="_blank"
      shortcut="g"
    >
      <span>[g]</span><span>github</span><ArrowUpRight size={16} />
    </NavLink>
  </nav>
</header>
